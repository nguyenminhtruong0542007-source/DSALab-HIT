struct SinhVien {

    string ten;

    string mssv;

    float diem;

};

SinhVien ds[100];

int n = 0;


void Them() {

    cin.ignore();

    cout << "\nTen: ";
    getline(cin, ds[n].ten);

    cout << "MSSV: ";
    getline(cin, ds[n].mssv);

    cout << "Diem: ";
    cin >> ds[n].diem;

    n++;
}


void Tim() {

    string x;

    cin.ignore();

    cout << "\nNhap ten: ";

    getline(cin, x);

    for (int i = 0; i < n; i++) {

        if (ds[i].ten.find(x) != string::npos) {

            cout
                << ds[i].ten
                << " - "
                << ds[i].mssv
                << " - "
                << ds[i].diem
                << endl;
        }
    }
}


void SapXep() {

    for (int i = 0; i < n - 1; i++)

        for (int j = i + 1; j < n; j++)

            if (ds[i].diem < ds[j].diem)

                swap(ds[i], ds[j]);
}


void BaoCao() {

    ofstream f("diem_sinhvien.txt");

    float tong = 0;

    float max = ds[0].diem;

    float min = ds[0].diem;

    for (int i = 0; i < n; i++) {

        tong += ds[i].diem;

        if (ds[i].diem > max)
            max = ds[i].diem;

        if (ds[i].diem < min)
            min = ds[i].diem;

        f
            << ds[i].ten
            << " "
            << ds[i].mssv
            << " "
            << ds[i].diem
            << endl;
    }

    cout << "\nDiem TB = "
        << tong / n;

    cout << "\nMax = "
        << max;

    cout << "\nMin = "
        << min;

    f.close();
}


