//======================
// LINEAR SEARCH
//======================
int LinearSearch(int a[], int n, int x, int& buoc) {
    buoc = 0;

    for (int i = 0; i < n; i++) {
        buoc++;

        if (a[i] == x)
            return i;
    }

    return -1;
}

//======================
// BINARY SEARCH ITERATIVE
//======================
int BinarySearch(int a[], int n, int x, int& buoc) {

    int l = 0;
    int r = n - 1;

    buoc = 0;

    while (l <= r) {

        buoc++;

        int m = (l + r) / 2;

        if (a[m] == x)
            return m;

        if (a[m] < x)
            l = m + 1;
        else
            r = m - 1;
    }

    return -1;
}

//======================
// BINARY SEARCH RECURSIVE
//======================
int BinarySearchDQ(
    int a[],
    int l,
    int r,
    int x
) {

    if (l > r)
        return -1;

    int m = (l + r) / 2;

    if (a[m] == x)
        return m;

    if (a[m] > x)
        return BinarySearchDQ(a, l, m - 1, x);

    return BinarySearchDQ(a, m + 1, r, x);
}

//======================
// SMART SEARCH TEN
//======================
void TimTen(string ds[], string sdt[], int n, string key) {

    bool found = false;

    cout << "\nKet qua:\n";

    for (int i = 0;i < n;i++) {

        if (ds[i].find(key) != string::npos) {

            found = true;

            cout
                << i + 1
                << ". "
                << ds[i]
                << " - "
                << sdt[i]
                << endl;
        }
    }

    if (!found)
        cout << "Khong tim thay\n";
}

